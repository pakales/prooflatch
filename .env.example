# Optional locally; without it ProofLatch uses deterministic fallback mode.
OPENAI_API_KEY=

# Required in production for the HMAC-pseudonymized D1 quota.
# Use a random value of at least 32 characters and keep it server-only.
PROOFLATCH_QUOTA_SALT=

# Set to the canonical deployed origin so Open Graph URLs are absolute.
PROOFLATCH_SITE_URL=http://localhost:3000
