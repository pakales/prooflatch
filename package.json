{
  "name": "prooflatch",
  "version": "1.0.0",
  "description": "A deterministic release-evidence gate with GPT-5.6 explanations and Codex-ready repair briefs.",
  "private": true,
  "license": "MIT",
  "bin": {
    "prooflatch-scan": "bin/prooflatch-scan.mjs"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "scan": "node bin/prooflatch-scan.mjs",
    "test": "npm run test:unit && npm run build && node --test tests/rendered-html.test.mjs",
    "test:unit": "node --experimental-test-module-mocks --import tsx --test tests/prooflatch-engine.test.mjs tests/prooflatch-scan.test.mjs tests/api-analyze.test.mjs",
    "test:api": "node --experimental-test-module-mocks --import tsx --test tests/api-analyze.test.mjs",
    "test:engine": "node --import tsx --test tests/prooflatch-engine.test.mjs",
    "test:scanner": "node --import tsx --test tests/prooflatch-scan.test.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "audit:prod": "npm audit --omit=dev",
    "verify": "npm run typecheck && npm run lint && npm test && npm run audit:prod",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "openai": "^6.48.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@cloudflare/workers-types": "^5.20260718.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "^8.1.5",
    "wrangler": "^4.112.0"
  },
  "overrides": {
    "postcss": "8.5.14",
    "ws": "8.21.0"
  },
  "type": "module"
}
